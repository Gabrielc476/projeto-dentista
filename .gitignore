# Monorepo Root gitignore

# Dependencies
node_modules/
**/node_modules/

# Next.js build outputs
.next/
**/out/
**/build/

# NestJS build outputs
dist/
**/dist/

# Environment variables
.env
.env.local
.env.*.local
**/ .env
**/ .env.local
**/ .env.*.local
**/.env
**/.env.production

# IDEs and Editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Testing
coverage/
**/coverage/

# Temp
tmp/
temp/
